{
  "name": "local-llm-harness",
  "displayName": "Local LLM Harness",
  "description": "Drive a LAN-hosted llama.cpp LLM from VS Code with hard network isolation, workspace-scoped tools, and an approval-gated terminal.",
  "version": "1.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "media/**",
    "README.md",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localLlmHarness",
          "title": "Local LLM Harness",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "localLlmHarness": [
        {
          "id": "localLlmHarness.side",
          "name": "Harness",
          "type": "webview"
        },
        {
          "id": "localLlmHarness.chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "localLlmHarness.newChat",
        "title": "Local LLM: New Chat"
      },
      {
        "command": "localLlmHarness.openSettings",
        "title": "Local LLM: Open Settings"
      },
      {
        "command": "localLlmHarness.togglePlanMode",
        "title": "Local LLM: Toggle Plan Mode"
      },
      {
        "command": "localLlmHarness.compactNow",
        "title": "Local LLM: Compact Context"
      },
      {
        "command": "localLlmHarness.generateCommitMessage",
        "title": "Generate commit message with local-llm",
        "icon": {
          "light": "media/activity-bar-command-light.svg",
          "dark": "media/activity-bar-command-dark.svg"
        }
      },
      {
        "command": "localLlmHarness.generateCommitMessageNoStaged",
        "title": "Please stage changes before generating a commit message.",
        "icon": {
          "light": "media/activity-bar-command-light.svg",
          "dark": "media/activity-bar-command-dark.svg"
        }
      },
      {
        "command": "localLlmHarness.generateCommitMessageNoStagedWiggle",
        "title": "Please stage changes before generating a commit message.",
        "icon": {
          "light": "media/activity-bar-command-wiggle-light.svg",
          "dark": "media/activity-bar-command-wiggle-dark.svg"
        }
      },
      {
        "command": "localLlmHarness.generateCommitMessageBusy",
        "title": "Generating commit message with local-llm...",
        "icon": {
          "light": "media/activity-bar-command-spin-light.svg",
          "dark": "media/activity-bar-command-spin-dark.svg"
        }
      },
      {
        "command": "localLlmHarness.openChat",
        "title": "Local LLM: Open Chat"
      },
      {
        "command": "localLlmHarness.deleteChat",
        "title": "Local LLM: Delete Current Chat"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "localLlmHarness.generateCommitMessageNoStaged",
          "when": "false"
        },
        {
          "command": "localLlmHarness.generateCommitMessageNoStagedWiggle",
          "when": "false"
        },
        {
          "command": "localLlmHarness.generateCommitMessageBusy",
          "when": "false"
        }
      ],
      "scm/title": [
        {
          "command": "localLlmHarness.generateCommitMessageBusy",
          "when": "localLlmHarness.commitMessageBusy",
          "group": "navigation@1"
        },
        {
          "command": "localLlmHarness.generateCommitMessageNoStagedWiggle",
          "when": "!localLlmHarness.commitMessageBusy && localLlmHarness.commitMessageWiggle",
          "group": "navigation@1"
        },
        {
          "command": "localLlmHarness.generateCommitMessage",
          "when": "!localLlmHarness.commitMessageBusy && !localLlmHarness.commitMessageWiggle && localLlmHarness.hasStagedChanges",
          "group": "navigation@1"
        },
        {
          "command": "localLlmHarness.generateCommitMessageNoStaged",
          "when": "!localLlmHarness.commitMessageBusy && !localLlmHarness.commitMessageWiggle && !localLlmHarness.hasStagedChanges",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Local LLM Harness",
      "properties": {
        "localLlmHarness.endpoint": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the llama.cpp server. Use localhost or a private IP literal such as http://127.0.0.1:8080 or http://192.168.1.50:8080; DNS hostnames are refused."
        },
        "localLlmHarness.modelFamily": {
          "type": "string",
          "enum": [
            "gemma4",
            "qwen3"
          ],
          "default": "gemma4",
          "description": "How the served model's output is parsed for tool calls and reasoning. 'gemma4' = Gemma native <|tool_call> blocks; 'qwen3' = Qwen/ChatML (Hermes <tool_call> JSON, <think> reasoning)."
        },
        "localLlmHarness.contextSize": {
          "type": "number",
          "default": 32768,
          "description": "Total context window of the model (tokens)."
        },
        "localLlmHarness.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for chat requests. Lower is more deterministic, higher more varied."
        },
        "localLlmHarness.topK": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "description": "Top-k sampling: keep only the K most likely tokens at each step (0 disables)."
        },
        "localLlmHarness.topP": {
          "type": "number",
          "default": 0.95,
          "minimum": 0,
          "maximum": 1,
          "description": "Top-p (nucleus) sampling: keep the smallest token set whose cumulative probability reaches p (1 disables)."
        },
        "localLlmHarness.autoCompact": {
          "type": "boolean",
          "default": true,
          "description": "Automatically compact context when usage reaches the configured threshold."
        },
        "localLlmHarness.autoCompactThresholdPercent": {
          "type": "number",
          "default": 80,
          "minimum": 50,
          "maximum": 95,
          "description": "Context usage percentage at which auto-compaction runs."
        },
        "localLlmHarness.autoapproveReads": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve read_file / list_dir / glob tool calls."
        },
        "localLlmHarness.autoapproveWrites": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve file edit tool calls (workspace only)."
        },
        "localLlmHarness.safeCommands": {
          "type": "array",
          "default": [
            {
              "match": "pwd",
              "description": "Print the current workspace directory."
            },
            {
              "match": "ls(?: -(?:l|a|la|al))?(?: (?:\\.|(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*))?",
              "description": "List the workspace root or a simple relative path."
            },
            {
              "match": "cat (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*",
              "description": "Print a file at a simple relative workspace path."
            },
            {
              "match": "grep(?: -[rRnil]{1,4}){0,4} (?:[A-Za-z0-9_./:@%+=,-]+|\"[A-Za-z0-9_./:@%+=, -]+\"|'[A-Za-z0-9_./:@%+=, -]+') (?:\\.|(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*)",
              "description": "Search for a simple text pattern in a simple relative workspace path."
            },
            {
              "match": "mkdir(?: -p)? (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*",
              "description": "Create a directory at a simple relative workspace path."
            },
            {
              "match": "mv (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))* (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*",
              "description": "Move or rename a file or directory between simple relative workspace paths."
            },
            {
              "match": "cp (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))* (?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*)(?:/(?:\\.[A-Za-z0-9][A-Za-z0-9._-]*|[A-Za-z0-9][A-Za-z0-9._-]*))*",
              "description": "Copy a file or directory between simple relative workspace paths."
            },
            {
              "match": "find \\. -maxdepth [1-3] -type f",
              "description": "List workspace files with a shallow max depth."
            },
            {
              "match": "git (?:status|diff|log(?: -[0-9]+)?)",
              "description": "Read-only git inspection commands."
            }
          ],
          "description": "Allow-list of safe shell commands. Each entry is a regex matched against the full command string.",
          "items": {
            "type": "object",
            "required": [
              "match"
            ],
            "properties": {
              "match": {
                "type": "string",
                "description": "Regex (full-string match) for the command."
              },
              "description": {
                "type": "string",
                "description": "Human-readable purpose."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src test --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "package:vsix": "node scripts/package-vsix.mjs",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "katex": "^0.16.10",
    "markdown-it": "^14.1.0",
    "shiki": "^4.1.0"
  },
  "overrides": {
    "undici": "^6.21.0"
  }
}
